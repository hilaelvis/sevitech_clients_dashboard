<%- include('partials/head') %>
<%- include('partials/content-start') %>

<style>
  .tab-btn-active   { background: white; color: #3b82f6; box-shadow: 0 1px 3px rgba(0,0,0,.1); }
  .tab-btn-inactive { color: #6b7280; }
  .dark .tab-btn-active   { background: #374151; color: #60a5fa; }
  .dark .tab-btn-inactive { color: #9ca3af; }
</style>

<div class="max-w-2xl mx-auto">

  <!-- Page header -->
  <div class="mb-6">
    <h3 class="text-lg text-gray-500 dark:text-gray-400">Scrape Google Maps to find new leads. Results appear in the Clients page automatically.</h3>
  </div>

  <!-- Card -->
  <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6">

    <!-- Mode tabs -->
    <div class="flex space-x-1 bg-gray-100 dark:bg-gray-700 rounded-lg p-1 mb-6">
      <button type="button" id="tab-keywords" class="flex-1 py-2 px-4 rounded-md text-sm font-medium transition tab-btn-active">
        <i class="fas fa-keyboard mr-2"></i>By Keywords
      </button>
      <button type="button" id="tab-maps" class="flex-1 py-2 px-4 rounded-md text-sm font-medium transition tab-btn-inactive">
        <i class="fas fa-map-marker-alt mr-2"></i>By Maps URL
      </button>
    </div>

    <form id="scraper-form" novalidate>

      <!-- Keywords panel -->
      <div id="panel-keywords">
        <div class="mb-4">
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
            Keywords <span class="text-gray-400 font-normal">(one per line)</span>
          </label>
          <textarea id="keywords" name="keywords" rows="5"
            placeholder="impresa di pulizie&#10;imprese di pulizie&#10;servizi di pulizia"
            class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 dark:bg-gray-700 dark:text-white font-mono text-sm resize-y"></textarea>
        </div>
      </div>

      <!-- Maps URL panel -->
      <div id="panel-maps" class="hidden">
        <div class="mb-4">
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Google Maps URL</label>
          <input type="text" id="maps_url" name="maps_url"
            placeholder="https://www.google.com/maps/search/restaurants/@41.327,19.818,14z"
            class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 dark:bg-gray-700 dark:text-white">
          <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">Open Google Maps, search for a category and area, then copy the URL — the zoom level controls the search radius.</p>
        </div>
      </div>

      <!-- City + Category tag (apply to all results from this scrape) -->
      <div class="flex gap-4 mb-4">
        <div class="flex-1">
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
            City
          </label>
          <input type="text" id="city" name="city"
            placeholder="e.g. Milano"
            class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 dark:bg-gray-700 dark:text-white text-sm">
        </div>
        <div class="flex-1">
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
            Category <span class="text-gray-400 font-normal">(optional — overrides auto-detect)</span>
          </label>
          <select id="category_tag" name="category_tag"
            class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 dark:bg-gray-700 dark:text-white text-sm">
            <option value="">Auto-detect</option>
            <option value="restaurant">Restaurant</option>
            <option value="hotel">Hotel</option>
            <option value="cleaning">Cleaning</option>
            <option value="clinic">Clinic</option>
            <option value="real_estate">Real Estate</option>
            <option value="generic">Generic</option>
          </select>
        </div>
      </div>

      <!-- Max results + test mode -->
      <div class="flex items-end gap-4 mb-6">
        <div class="w-36">
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Max results</label>
          <input type="number" id="max_results" name="max_results"
            value="50" min="1" max="500"
            class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 dark:bg-gray-700 dark:text-white">
        </div>
        <div class="flex items-center gap-2 pb-3">
          <input type="checkbox" id="test_mode" class="w-4 h-4 text-blue-500 rounded">
          <label for="test_mode" class="text-sm text-gray-600 dark:text-gray-400 cursor-pointer">
            Test mode <span class="text-xs text-gray-400">(n8n must be listening)</span>
          </label>
        </div>
      </div>

      <!-- Submit -->
      <button type="submit" id="submit-btn"
        class="w-full bg-blue-500 hover:bg-blue-600 text-white font-semibold py-3 rounded-lg transition flex items-center justify-center space-x-2">
        <i class="fas fa-search" id="btn-icon"></i>
        <span id="btn-text">Start Scraping</span>
      </button>

    </form>

    <!-- Submit error message -->
    <div id="status-msg" class="hidden mt-4 px-4 py-3 rounded-lg text-sm"></div>

    <!-- Live scraping progress (shown after successful trigger) -->
    <div id="live-panel" class="hidden mt-4">
      <div id="live-status" class="px-4 py-3 rounded-lg text-sm"></div>
      <div class="mt-2 text-xs text-gray-400 dark:text-gray-500 text-right">
        <a href="#" id="stop-watching" class="hover:underline">stop watching</a>
      </div>
    </div>

    <!-- Info note -->
    <div class="mt-6 pt-4 border-t border-gray-200 dark:border-gray-700 flex items-start gap-3 text-xs text-gray-500 dark:text-gray-400">
      <i class="fas fa-info-circle mt-0.5 flex-shrink-0"></i>
      <span>Scraping runs in the background and takes <strong>1–3 minutes</strong> depending on result count. New clients will appear in the <a href="/clients" class="text-blue-500 hover:underline">Clients page</a> automatically.</span>
    </div>
  </div>
</div>

<script>
(function () {
  var currentTab = 'keywords';

  function switchTab(tab) {
    currentTab = tab;
    document.getElementById('panel-keywords').classList.toggle('hidden', tab !== 'keywords');
    document.getElementById('panel-maps').classList.toggle('hidden', tab !== 'maps');
    document.getElementById('tab-keywords').className = 'flex-1 py-2 px-4 rounded-md text-sm font-medium transition ' + (tab === 'keywords' ? 'tab-btn-active' : 'tab-btn-inactive');
    document.getElementById('tab-maps').className     = 'flex-1 py-2 px-4 rounded-md text-sm font-medium transition ' + (tab === 'maps'     ? 'tab-btn-active' : 'tab-btn-inactive');
  }

  document.getElementById('tab-keywords').addEventListener('click', function () { switchTab('keywords'); });
  document.getElementById('tab-maps').addEventListener('click', function () { switchTab('maps'); });

  // ── Live polling state ──────────────────────────────────────────────────────
  var poll = { city: '', category: '', baseline: 0, lastDelta: 0, stableRuns: 0, timer: null, tick: 0 };

  function startPolling(city, category, baseline) {
    stopPolling();
    poll.city = city; poll.category = category; poll.baseline = baseline || 0;
    poll.lastDelta = 0; poll.stableRuns = 0; poll.tick = 0;
    document.getElementById('live-panel').classList.remove('hidden');
    setLiveStatus(0, false);
    // First check after 15 s (give n8n time to start), then every 12 s
    setTimeout(doPoll, 15000);
    poll.timer = setInterval(doPoll, 12000);
  }

  function stopPolling() {
    if (poll.timer) { clearInterval(poll.timer); poll.timer = null; }
  }

  async function doPoll() {
    poll.tick++;
    try {
      var p = new URLSearchParams();
      if (poll.city)     p.set('city', poll.city);
      if (poll.category) p.set('category', poll.category);
      var r = await fetch('/search/poll?' + p.toString(), { headers: { Accept: 'application/json' } });
      var d = await r.json();
      if (!d.ok) return;
      var delta = Math.max(0, d.count - poll.baseline);
      if (delta === poll.lastDelta) { poll.stableRuns++; } else { poll.stableRuns = 0; poll.lastDelta = delta; }
      // Done: stable for 3 polls after at least one new record, or stable 5 polls regardless, or 6-min timeout
      var done = (poll.stableRuns >= 3 && delta > 0) || poll.stableRuns >= 5 || poll.tick >= 30;
      setLiveStatus(delta, done);
      if (done) stopPolling();
    } catch (_) { /* ignore transient errors */ }
  }

  function setLiveStatus(count, done) {
    var el = document.getElementById('live-status');
    if (done) {
      if (count > 0) {
        el.className = 'px-4 py-3 rounded-lg text-sm bg-green-50 dark:bg-green-900/20 text-green-700 dark:text-green-300 border border-green-200 dark:border-green-800';
        el.innerHTML = '<i class="fas fa-check-circle mr-2"></i>Done! <strong>' + count + ' new client' + (count === 1 ? '' : 's') + '</strong> added to Airtable. <a href="/clients" class="underline font-medium ml-1">View clients</a>';
      } else {
        el.className = 'px-4 py-3 rounded-lg text-sm bg-yellow-50 dark:bg-yellow-900/20 text-yellow-700 dark:text-yellow-300 border border-yellow-200 dark:border-yellow-800';
        el.innerHTML = '<i class="fas fa-check-circle mr-2"></i>Scraping finished — no new records found (all results may already exist in Airtable).';
      }
    } else {
      el.className = 'px-4 py-3 rounded-lg text-sm bg-blue-50 dark:bg-blue-900/20 text-blue-700 dark:text-blue-300 border border-blue-200 dark:border-blue-800';
      el.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i>Scraping in progress&hellip; <strong>' + count + ' new client' + (count === 1 ? '' : 's') + '</strong> found so far.';
    }
  }

  document.getElementById('stop-watching').addEventListener('click', function (e) {
    e.preventDefault();
    stopPolling();
    document.getElementById('live-panel').classList.add('hidden');
  });

  // ── Form submit ─────────────────────────────────────────────────────────────
  document.getElementById('scraper-form').addEventListener('submit', async function (e) {
    e.preventDefault();
    e.stopPropagation();

    var keywords     = document.getElementById('keywords').value.trim();
    var maps_url     = document.getElementById('maps_url').value.trim();
    var max_results  = document.getElementById('max_results').value;
    var test_mode    = document.getElementById('test_mode').checked;
    var city         = document.getElementById('city').value.trim();
    var category_tag = document.getElementById('category_tag').value;

    if (currentTab === 'keywords' && !keywords) { showStatus('Please enter at least one keyword.', 'error'); return; }
    if (currentTab === 'maps'     && !maps_url)  { showStatus('Please enter a Google Maps URL.', 'error');  return; }

    setLoading(true);
    hideStatus();
    stopPolling();
    document.getElementById('live-panel').classList.add('hidden');

    try {
      var body = { max_results: max_results, test_mode: String(test_mode) };
      if (currentTab === 'keywords') { body.keywords = keywords; if (city) body.location = city; }
      if (currentTab === 'maps')     { body.maps_url = maps_url; }
      if (city)         body.city = city;
      if (category_tag) body.category = category_tag;

      var res = await fetch('/search/run', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify(body)
      });

      var data = await res.json();

      if (data.ok) {
        document.getElementById('keywords').value = '';
        document.getElementById('maps_url').value = '';
        document.getElementById('max_results').value = '50';
        document.getElementById('city').value = '';
        document.getElementById('category_tag').value = '';
        startPolling(city, category_tag, data.baseline);
      } else {
        showStatus('Error: ' + (data.error || 'Unknown error'), 'error');
      }
    } catch (err) {
      showStatus('Network error — could not reach the server.', 'error');
    } finally {
      setLoading(false);
    }
  });

  function setLoading(loading) {
    var btn  = document.getElementById('submit-btn');
    var icon = document.getElementById('btn-icon');
    var text = document.getElementById('btn-text');
    btn.disabled = loading;
    icon.className = loading ? 'fas fa-spinner fa-spin' : 'fas fa-search';
    text.textContent = loading ? 'Sending to scraper…' : 'Start Scraping';
    btn.classList.toggle('opacity-75', loading);
  }

  function showStatus(msg, type) {
    var el = document.getElementById('status-msg');
    el.className = 'mt-4 px-4 py-3 rounded-lg text-sm ' +
      (type === 'success'
        ? 'bg-green-50 dark:bg-green-900/20 text-green-700 dark:text-green-300 border border-green-200 dark:border-green-800'
        : 'bg-red-50 dark:bg-red-900/20 text-red-700 dark:text-red-300 border border-red-200 dark:border-red-800');
    el.innerHTML = msg;
  }

  function hideStatus() {
    document.getElementById('status-msg').className = 'hidden';
  }
}());
</script>

<%- include('partials/content-end') %>
<%- include('partials/footer') %>
