  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - Sevitech Dashboard</title>

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="alternate icon" href="/favicon.ico">
