<%- include('partials/head') %>
<%- include('partials/content-start') %>

<!-- Date range selector -->
<div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6 mb-6">
  <form method="GET" action="/analytics" class="flex items-center space-x-4">
    <label class="text-sm font-medium text-gray-700 dark:text-gray-300">Date Range:</label>
    <select
      name="range"
      onchange="this.form.submit()"
      class="px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 dark:bg-gray-700 dark:text-white"
    >
      <option value="7" <%= dateRange === 7 ? 'selected' : '' %>>Last 7 Days</option>
      <option value="30" <%= dateRange === 30 ? 'selected' : '' %>>Last 30 Days</option>
      <option value="90" <%= dateRange === 90 ? 'selected' : '' %>>Last 90 Days</option>
      <option value="365" <%= dateRange === 365 ? 'selected' : '' %>>Last Year</option>
    </select>
  </form>
</div>

<!-- Stats cards -->
<div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
  <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6">
    <div class="flex items-center justify-between">
      <div>
        <p class="text-sm text-gray-600 dark:text-gray-400">Total Messages</p>
        <p class="text-3xl font-bold text-gray-800 dark:text-white mt-2"><%= analytics.totalMessages %></p>
      </div>
      <div class="w-12 h-12 bg-blue-100 dark:bg-blue-900 rounded-full flex items-center justify-center">
        <i class="fas fa-envelope text-blue-500 text-xl"></i>
      </div>
    </div>
  </div>

  <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6">
    <div class="flex items-center justify-between">
      <div>
        <p class="text-sm text-gray-600 dark:text-gray-400">Total Clients</p>
        <p class="text-3xl font-bold text-gray-800 dark:text-white mt-2"><%= analytics.totalClients %></p>
      </div>
      <div class="w-12 h-12 bg-green-100 dark:bg-green-900 rounded-full flex items-center justify-center">
        <i class="fas fa-users text-green-500 text-xl"></i>
      </div>
    </div>
  </div>
</div>

<!-- Charts -->
<div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
  <!-- Messages over time -->
  <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6">
    <h3 class="text-lg font-semibold text-gray-800 dark:text-white mb-4">Messages Over Time</h3>
    <canvas id="messagesOverTimeChart"></canvas>
  </div>

  <!-- Platform breakdown -->
  <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6">
    <h3 class="text-lg font-semibold text-gray-800 dark:text-white mb-4">Platform Usage</h3>
    <canvas id="platformChart"></canvas>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
  <!-- Status breakdown -->
  <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6">
    <h3 class="text-lg font-semibold text-gray-800 dark:text-white mb-4">Client Status Distribution</h3>
    <canvas id="statusChart"></canvas>
  </div>

  <!-- Sender breakdown -->
  <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6">
    <h3 class="text-lg font-semibold text-gray-800 dark:text-white mb-4">Messages by Sender</h3>
    <canvas id="senderChart"></canvas>
  </div>
</div>

<script>
  const analytics = <%- JSON.stringify(analytics) %>;

  // Messages over time chart
  const messagesOverTimeCtx = document.getElementById('messagesOverTimeChart').getContext('2d');
  const dates = Object.keys(analytics.messagesOverTime).sort();
  const messageCounts = dates.map(date => analytics.messagesOverTime[date]);

  new Chart(messagesOverTimeCtx, {
    type: 'line',
    data: {
      labels: dates,
      datasets: [{
        label: 'Messages',
        data: messageCounts,
        borderColor: '#3b82f6',
        backgroundColor: 'rgba(59, 130, 246, 0.1)',
        tension: 0.4,
        fill: true
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: true,
      plugins: {
        legend: {
          display: false
        }
      },
      scales: {
        y: {
          beginAtZero: true,
          ticks: {
            precision: 0
          }
        }
      }
    }
  });

  // Platform chart
  const platformCtx = document.getElementById('platformChart').getContext('2d');
  new Chart(platformCtx, {
    type: 'bar',
    data: {
      labels: Object.keys(analytics.platformBreakdown),
      datasets: [{
        label: 'Messages',
        data: Object.values(analytics.platformBreakdown),
        backgroundColor: ['#10b981', '#f59e0b', '#8b5cf6']
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: true,
      plugins: {
        legend: {
          display: false
        }
      },
      scales: {
        y: {
          beginAtZero: true,
          ticks: {
            precision: 0
          }
        }
      }
    }
  });

  // Status chart
  const statusCtx = document.getElementById('statusChart').getContext('2d');
  new Chart(statusCtx, {
    type: 'doughnut',
    data: {
      labels: Object.keys(analytics.statusBreakdown),
      datasets: [{
        data: Object.values(analytics.statusBreakdown),
        backgroundColor: ['#3b82f6', '#eab308', '#10b981', '#6b7280']
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: true,
      plugins: {
        legend: {
          position: 'bottom'
        }
      }
    }
  });

  // Sender chart
  const senderCtx = document.getElementById('senderChart').getContext('2d');
  new Chart(senderCtx, {
    type: 'pie',
    data: {
      labels: Object.keys(analytics.senderBreakdown),
      datasets: [{
        data: Object.values(analytics.senderBreakdown),
        backgroundColor: ['#3b82f6', '#8b5cf6']
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: true,
      plugins: {
        legend: {
          position: 'bottom'
        }
      }
    }
  });
</script>

<%- include('partials/content-end') %>
<%- include('partials/footer') %>
