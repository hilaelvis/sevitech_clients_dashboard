<%- include('partials/head') %>
<%- include('partials/content-start') %>

<!-- Stats cards -->
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-6">
  <!-- Total Clients -->
  <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6">
    <div class="flex items-center justify-between">
      <div>
        <p class="text-sm text-gray-600 dark:text-gray-400">Total Clients</p>
        <p class="text-3xl font-bold text-gray-800 dark:text-white mt-2"><%= stats.totalClients %></p>
      </div>
      <div class="w-12 h-12 bg-blue-100 dark:bg-blue-900 rounded-full flex items-center justify-center">
        <i class="fas fa-users text-blue-500 text-xl"></i>
      </div>
    </div>
  </div>

  <!-- New Clients Today -->
  <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6">
    <div class="flex items-center justify-between">
      <div>
        <p class="text-sm text-gray-600 dark:text-gray-400">New Today</p>
        <p class="text-3xl font-bold text-gray-800 dark:text-white mt-2"><%= stats.newClientsToday %></p>
      </div>
      <div class="w-12 h-12 bg-green-100 dark:bg-green-900 rounded-full flex items-center justify-center">
        <i class="fas fa-user-plus text-green-500 text-xl"></i>
      </div>
    </div>
  </div>

  <!-- Active Conversations -->
  <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6">
    <div class="flex items-center justify-between">
      <div>
        <p class="text-sm text-gray-600 dark:text-gray-400">Active Conversations</p>
        <p class="text-3xl font-bold text-gray-800 dark:text-white mt-2"><%= stats.activeConversations %></p>
      </div>
      <div class="w-12 h-12 bg-purple-100 dark:bg-purple-900 rounded-full flex items-center justify-center">
        <i class="fas fa-comments text-purple-500 text-xl"></i>
      </div>
    </div>
  </div>

  <!-- Messages Today -->
  <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6">
    <div class="flex items-center justify-between">
      <div>
        <p class="text-sm text-gray-600 dark:text-gray-400">Messages Today</p>
        <p class="text-3xl font-bold text-gray-800 dark:text-white mt-2"><%= stats.messagesToday %></p>
      </div>
      <div class="w-12 h-12 bg-yellow-100 dark:bg-yellow-900 rounded-full flex items-center justify-center">
        <i class="fas fa-envelope text-yellow-500 text-xl"></i>
      </div>
    </div>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
  <!-- Status Breakdown Chart -->
  <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6">
    <h3 class="text-lg font-semibold text-gray-800 dark:text-white mb-4">Client Status Breakdown</h3>
    <canvas id="statusChart"></canvas>
  </div>

  <!-- Recent Conversations -->
  <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6">
    <h3 class="text-lg font-semibold text-gray-800 dark:text-white mb-4">Recent Conversations</h3>
    <div class="space-y-2 max-h-96 overflow-y-auto">
      <% if (recentActivity.length === 0) { %>
        <p class="text-gray-500 dark:text-gray-400 text-center py-8">No recent conversations</p>
      <% } else { %>
        <% recentActivity.forEach(function(conversation) { %>
          <% if (conversation.clientId) { %>
            <a href="/clients/<%= conversation.clientId %>" class="block p-3 hover:bg-gray-50 dark:hover:bg-gray-700 rounded-lg transition border-l-4 <%= conversation.clientStatus === 'New' ? 'border-blue-500' : conversation.clientStatus === 'Responded' ? 'border-yellow-500' : conversation.clientStatus === 'Interested' ? 'border-green-500' : 'border-gray-500' %>">
              <div class="flex items-start space-x-3">
                <div class="flex-shrink-0 w-12 h-12 bg-gradient-to-br from-blue-500 to-blue-600 rounded-full flex items-center justify-center">
                  <span class="text-white font-semibold text-lg"><%= conversation.clientName ? conversation.clientName.charAt(0).toUpperCase() : '?' %></span>
                </div>
                <div class="flex-1 min-w-0">
                  <div class="flex items-center justify-between mb-1">
                    <p class="text-sm font-semibold text-gray-800 dark:text-white">
                      <%= conversation.clientName %>
                    </p>
                    <span class="text-xs text-gray-500 dark:text-gray-400">
                      <%= formatRelativeTime(conversation.timestamp) %>
                    </span>
                  </div>
                  <p class="text-xs text-gray-600 dark:text-gray-400 mb-1">
                    <i class="fas fa-phone mr-1"></i><%= conversation.clientPhone %>
                  </p>
                  <div class="flex items-center space-x-2 mb-1">
                    <span class="px-2 py-0.5 text-xs font-semibold rounded-full <%= conversation.clientStatus === 'New' ? 'bg-blue-100 text-blue-800' : conversation.clientStatus === 'Responded' ? 'bg-yellow-100 text-yellow-800' : conversation.clientStatus === 'Interested' ? 'bg-green-100 text-green-800' : 'bg-gray-100 text-gray-800' %>">
                      <%= conversation.clientStatus %>
                    </span>
                    <span class="text-xs text-gray-500">
                      <i class="fab fa-whatsapp"></i> WhatsApp
                    </span>
                  </div>
                  <p class="text-sm text-gray-600 dark:text-gray-400 truncate">
                    <i class="fas fa-comment-dots mr-1"></i>
                    <%= conversation.message_text %>
                  </p>
                </div>
                <div class="flex-shrink-0">
                  <i class="fas fa-chevron-right text-gray-400"></i>
                </div>
              </div>
            </a>
          <% } %>
        <% }) %>
      <% } %>
    </div>
  </div>
</div>

<!-- Analytics Section -->
<div class="mt-6">
  <h2 class="text-2xl font-bold text-gray-800 dark:text-white mb-6">Analytics (Last 30 Days)</h2>

  <!-- Charts -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
    <!-- Messages over time -->
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6">
      <h3 class="text-lg font-semibold text-gray-800 dark:text-white mb-4">Messages Over Time</h3>
      <canvas id="messagesOverTimeChart"></canvas>
    </div>

    <!-- Platform breakdown -->
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6">
      <h3 class="text-lg font-semibold text-gray-800 dark:text-white mb-4">Platform Usage</h3>
      <canvas id="platformChart"></canvas>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <!-- Sender breakdown -->
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6">
      <h3 class="text-lg font-semibold text-gray-800 dark:text-white mb-4">Messages by Sender</h3>
      <canvas id="senderChart"></canvas>
    </div>

    <!-- Status breakdown (duplicate from above for analytics) -->
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6">
      <h3 class="text-lg font-semibold text-gray-800 dark:text-white mb-4">Client Status Distribution</h3>
      <canvas id="analyticsStatusChart"></canvas>
    </div>
  </div>
</div>

<script>
  // Status breakdown chart
  const ctx = document.getElementById('statusChart').getContext('2d');
  new Chart(ctx, {
    type: 'pie',
    data: {
      labels: ['New', 'Responded', 'Interested', 'Closed'],
      datasets: [{
        data: [
          <%= stats.statusBreakdown.New %>,
          <%= stats.statusBreakdown.Responded %>,
          <%= stats.statusBreakdown.Interested %>,
          <%= stats.statusBreakdown.Closed %>
        ],
        backgroundColor: [
          '#3b82f6',
          '#eab308',
          '#10b981',
          '#6b7280'
        ]
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: true,
      plugins: {
        legend: {
          position: 'bottom',
        }
      }
    }
  });

  // Auto-refresh stats every 30 seconds
  setInterval(async () => {
    try {
      const response = await fetch('/dashboard/api/stats');
      const stats = await response.json();

      // Update stats on page
      document.querySelectorAll('.text-3xl')[0].textContent = stats.totalClients;
      document.querySelectorAll('.text-3xl')[1].textContent = stats.newClientsToday;
      document.querySelectorAll('.text-3xl')[2].textContent = stats.activeConversations;
      document.querySelectorAll('.text-3xl')[3].textContent = stats.messagesToday;
    } catch (error) {
      console.error('Failed to refresh stats:', error);
    }
  }, 30000);

  // Analytics charts
  const analytics = <%- JSON.stringify(analytics) %>;

  // Messages over time chart
  const messagesOverTimeCtx = document.getElementById('messagesOverTimeChart').getContext('2d');
  const dates = Object.keys(analytics.messagesOverTime).sort();
  const messageCounts = dates.map(date => analytics.messagesOverTime[date]);

  new Chart(messagesOverTimeCtx, {
    type: 'line',
    data: {
      labels: dates,
      datasets: [{
        label: 'Messages',
        data: messageCounts,
        borderColor: '#3b82f6',
        backgroundColor: 'rgba(59, 130, 246, 0.1)',
        tension: 0.4,
        fill: true
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: true,
      plugins: {
        legend: {
          display: false
        }
      },
      scales: {
        y: {
          beginAtZero: true,
          ticks: {
            precision: 0
          }
        }
      }
    }
  });

  // Platform chart
  const platformCtx = document.getElementById('platformChart').getContext('2d');
  new Chart(platformCtx, {
    type: 'bar',
    data: {
      labels: Object.keys(analytics.platformBreakdown),
      datasets: [{
        label: 'Messages',
        data: Object.values(analytics.platformBreakdown),
        backgroundColor: ['#10b981', '#f59e0b', '#8b5cf6']
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: true,
      plugins: {
        legend: {
          display: false
        }
      },
      scales: {
        y: {
          beginAtZero: true,
          ticks: {
            precision: 0
          }
        }
      }
    }
  });

  // Sender chart
  const senderCtx = document.getElementById('senderChart').getContext('2d');
  new Chart(senderCtx, {
    type: 'pie',
    data: {
      labels: Object.keys(analytics.senderBreakdown),
      datasets: [{
        data: Object.values(analytics.senderBreakdown),
        backgroundColor: ['#3b82f6', '#8b5cf6']
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: true,
      plugins: {
        legend: {
          position: 'bottom'
        }
      }
    }
  });

  // Analytics status chart (doughnut)
  const analyticsStatusCtx = document.getElementById('analyticsStatusChart').getContext('2d');
  new Chart(analyticsStatusCtx, {
    type: 'doughnut',
    data: {
      labels: Object.keys(analytics.statusBreakdown),
      datasets: [{
        data: Object.values(analytics.statusBreakdown),
        backgroundColor: ['#3b82f6', '#eab308', '#10b981', '#6b7280']
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: true,
      plugins: {
        legend: {
          position: 'bottom'
        }
      }
    }
  });
</script>

<%- include('partials/content-end') %>
<%- include('partials/footer') %>
