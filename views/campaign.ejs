<%- include('partials/head') %>
<%- include('partials/content-start') %>

<div class="max-w-xl mx-auto">

  <div class="mb-6">
    <h3 class="text-lg text-gray-500 dark:text-gray-400">
      Send a first-contact WhatsApp message to leads with status <strong class="text-gray-700 dark:text-gray-300">New</strong>, filtered by category. Messages are sent via <strong class="text-gray-700 dark:text-gray-300">+39 3510218513</strong> with a 30-second delay between each.
    </h3>
  </div>

  <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6">

    <form id="campaign-form" novalidate>

      <!-- Category -->
      <div class="mb-5">
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
          <i class="fas fa-filter mr-2 text-gray-400"></i>Category
        </label>
        <select id="category" name="category"
          class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 dark:bg-gray-700 dark:text-white text-sm">
          <option value="">All categories</option>
          <option value="restaurant">Restaurant</option>
          <option value="hotel">Hotel</option>
          <option value="cleaning">Cleaning</option>
          <option value="clinic">Clinic</option>
          <option value="real_estate">Real Estate</option>
          <option value="generic">Generic</option>
        </select>
        <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">Leave as "All" to target every New lead regardless of category.</p>
      </div>

      <!-- City filter -->
      <div class="mb-5">
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
          <i class="fas fa-map-marker-alt mr-2 text-gray-400"></i>City
        </label>
        <input type="text" id="city" name="city"
          placeholder="e.g. Milano (leave blank for all cities)"
          class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 dark:bg-gray-700 dark:text-white text-sm">
        <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">Leave blank to target leads in all cities.</p>
      </div>

      <!-- Limit -->
      <div class="mb-5">
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
          <i class="fas fa-paper-plane mr-2 text-gray-400"></i>How many to send
        </label>
        <input type="number" id="limit" name="limit"
          value="20" min="1" max="200"
          class="w-40 px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 dark:bg-gray-700 dark:text-white text-sm">
        <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">Max 200 per campaign run.</p>
      </div>

      <!-- Message -->
      <div class="mb-6">
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
          <i class="fab fa-whatsapp mr-2 text-gray-400"></i>Message
        </label>
        <textarea id="message" name="message" rows="6"
          placeholder="Write your WhatsApp message here…"
          class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 dark:bg-gray-700 dark:text-white text-sm resize-y"></textarea>
        <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">This exact text will be sent to each lead.</p>
      </div>

      <!-- Test mode -->
      <div class="mb-5 flex items-center gap-2">
        <input type="checkbox" id="test_mode" class="w-4 h-4 text-blue-500 rounded">
        <label for="test_mode" class="text-sm text-gray-600 dark:text-gray-400 cursor-pointer">
          Test mode <span class="text-xs text-gray-400">(n8n must be listening)</span>
        </label>
      </div>

      <!-- Warning banner -->
      <div class="mb-6 flex items-start gap-3 bg-yellow-50 dark:bg-yellow-900/20 border border-yellow-200 dark:border-yellow-800 rounded-lg px-4 py-3">
        <i class="fas fa-triangle-exclamation text-yellow-500 mt-0.5 flex-shrink-0"></i>
        <p class="text-xs text-yellow-700 dark:text-yellow-300">
          This will send real WhatsApp messages to leads. Double-check the message text before launching.
        </p>
      </div>

      <!-- Submit -->
      <button type="submit" id="submit-btn"
        class="w-full bg-green-500 hover:bg-green-600 text-white font-semibold py-3 rounded-lg transition flex items-center justify-center gap-2">
        <i class="fab fa-whatsapp text-lg" id="btn-icon"></i>
        <span id="btn-text">Launch Campaign</span>
      </button>

    </form>

    <!-- Status message -->
    <div id="status-msg" class="hidden mt-4 px-4 py-3 rounded-lg text-sm"></div>

    <!-- Info note -->
    <div class="mt-6 pt-4 border-t border-gray-200 dark:border-gray-700 flex items-start gap-3 text-xs text-gray-500 dark:text-gray-400">
      <i class="fas fa-info-circle mt-0.5 flex-shrink-0"></i>
      <span>Campaign runs in the background. With a 30-second delay between messages, sending 20 messages takes ~10 minutes. Only leads with status <strong>New</strong> are targeted.</span>
    </div>
  </div>
</div>

<script>
(function () {
  document.getElementById('campaign-form').addEventListener('submit', async function (e) {
    e.preventDefault();
    e.stopPropagation();

    var category  = document.getElementById('category').value;
    var city      = document.getElementById('city').value.trim();
    var limit     = parseInt(document.getElementById('limit').value) || 20;
    var message   = document.getElementById('message').value.trim();
    var test_mode = document.getElementById('test_mode').checked;

    if (limit < 1 || limit > 200) {
      showStatus('Please enter a number between 1 and 200.', 'error');
      return;
    }
    if (!message) {
      showStatus('Please enter a message before launching.', 'error');
      return;
    }

    setLoading(true);
    hideStatus();

    try {
      var res = await fetch('/campaign/run', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify({ category: category, city: city, limit: limit, message: message, test_mode: String(test_mode) })
      });

      var data = await res.json();

      if (!data.ok) {
        showStatus('Error: ' + (data.error || 'Unknown error'), 'error');
        return;
      }

      var categoryLabel = category ? category.charAt(0).toUpperCase() + category.slice(1).replace('_', ' ') : 'all categories';
      var cityLabel = city ? ' in <strong>' + city + '</strong>' : '';
      showStatus(
        '<i class="fab fa-whatsapp mr-2"></i>Campaign started — <strong>' + limit + ' messages</strong> will be sent to leads in <strong>' + categoryLabel + '</strong>' + cityLabel + '.',
        'success'
      );
    } catch (err) {
      showStatus('Network error — could not reach the API.', 'error');
    } finally {
      setLoading(false);
    }
  });

  function setLoading(loading) {
    var btn  = document.getElementById('submit-btn');
    var icon = document.getElementById('btn-icon');
    var text = document.getElementById('btn-text');
    btn.disabled = loading;
    icon.className = loading ? 'fas fa-spinner fa-spin' : 'fab fa-whatsapp text-lg';
    text.textContent = loading ? 'Launching campaign…' : 'Launch Campaign';
    btn.classList.toggle('opacity-75', loading);
  }

  function showStatus(msg, type) {
    var el = document.getElementById('status-msg');
    el.className = 'mt-4 px-4 py-3 rounded-lg text-sm ' +
      (type === 'success'
        ? 'bg-green-50 dark:bg-green-900/20 text-green-700 dark:text-green-300 border border-green-200 dark:border-green-800'
        : 'bg-red-50 dark:bg-red-900/20 text-red-700 dark:text-red-300 border border-red-200 dark:border-red-800');
    el.innerHTML = msg;
  }

  function hideStatus() {
    document.getElementById('status-msg').className = 'hidden';
  }
}());
</script>

<%- include('partials/content-end') %>
<%- include('partials/footer') %>
