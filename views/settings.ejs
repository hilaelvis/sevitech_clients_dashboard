<%- include('partials/head') %>
<%- include('partials/content-start') %>

<div class="max-w-2xl">
  <!-- Change Password -->
  <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6 mb-6">
    <h3 class="text-xl font-semibold text-gray-800 dark:text-white mb-6">Change Password</h3>

    <form method="POST" action="/settings/password" class="space-y-4">
      <div>
        <label for="currentPassword" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
          Current Password
        </label>
        <input
          type="password"
          id="currentPassword"
          name="currentPassword"
          required
          class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 dark:bg-gray-700 dark:text-white"
        >
      </div>

      <div>
        <label for="newPassword" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
          New Password
        </label>
        <input
          type="password"
          id="newPassword"
          name="newPassword"
          required
          minlength="6"
          class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 dark:bg-gray-700 dark:text-white"
        >
        <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">Minimum 6 characters</p>
      </div>

      <div>
        <label for="confirmPassword" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
          Confirm New Password
        </label>
        <input
          type="password"
          id="confirmPassword"
          name="confirmPassword"
          required
          minlength="6"
          class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 dark:bg-gray-700 dark:text-white"
        >
      </div>

      <button
        type="submit"
        class="w-full bg-blue-500 hover:bg-blue-600 text-white font-semibold py-2 px-4 rounded-lg transition"
      >
        <i class="fas fa-key mr-2"></i>Update Password
      </button>
    </form>
  </div>

  <!-- Airtable Configuration -->
  <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6 mb-6">
    <h3 class="text-xl font-semibold text-gray-800 dark:text-white mb-6">Airtable Configuration</h3>

    <div class="space-y-4">
      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
          API Key
        </label>
        <div class="flex items-center space-x-2">
          <input
            type="password"
            value="<%= process.env.AIRTABLE_API_KEY ? '••••••••••••••••' : 'Not configured' %>"
            disabled
            class="flex-1 px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-gray-50 dark:bg-gray-700 dark:text-white"
          >
          <span class="text-xs text-gray-500 dark:text-gray-400">
            <i class="fas fa-info-circle"></i> Set in .env file
          </span>
        </div>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
          Base ID
        </label>
        <div class="flex items-center space-x-2">
          <input
            type="password"
            value="<%= process.env.AIRTABLE_BASE_ID ? '••••••••••••••••' : 'Not configured' %>"
            disabled
            class="flex-1 px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-gray-50 dark:bg-gray-700 dark:text-white"
          >
          <span class="text-xs text-gray-500 dark:text-gray-400">
            <i class="fas fa-info-circle"></i> Set in .env file
          </span>
        </div>
      </div>

      <div class="bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 rounded-lg p-4">
        <p class="text-sm text-blue-800 dark:text-blue-300">
          <i class="fas fa-lightbulb mr-2"></i>
          To update Airtable credentials, edit the <code class="bg-blue-100 dark:bg-blue-900 px-2 py-1 rounded">.env</code> file and restart the server.
        </p>
      </div>
    </div>
  </div>

  <!-- User Preferences -->
  <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6">
    <h3 class="text-xl font-semibold text-gray-800 dark:text-white mb-6">Preferences</h3>

    <div class="space-y-4">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm font-medium text-gray-700 dark:text-gray-300">Dark Mode</p>
          <p class="text-xs text-gray-500 dark:text-gray-400">Toggle dark mode theme</p>
        </div>
        <div class="flex items-center space-x-3">
          <span class="text-sm text-gray-600 dark:text-gray-400">
            <i class="fas fa-sun mr-1"></i>Light
          </span>
          <!-- Toggle Switch -->
          <button id="settings-theme-toggle" class="relative inline-flex h-7 w-14 items-center rounded-full transition-colors focus:outline-none focus:ring-2 focus:ring-blue-500 bg-gray-300 dark:bg-blue-600">
            <span class="inline-block h-5 w-5 transform rounded-full bg-white transition-transform translate-x-1 dark:translate-x-8"></span>
          </button>
          <span class="text-sm text-gray-600 dark:text-gray-400">
            <i class="fas fa-moon mr-1"></i>Dark
          </span>
        </div>
      </div>

      <div class="flex items-center justify-between pt-4 border-t border-gray-200 dark:border-gray-700">
        <div>
          <p class="text-sm font-medium text-gray-700 dark:text-gray-300">Session Timeout</p>
          <p class="text-xs text-gray-500 dark:text-gray-400">30 minutes of inactivity</p>
        </div>
        <span class="text-sm text-gray-600 dark:text-gray-400">
          <i class="fas fa-clock"></i> 30 min
        </span>
      </div>
    </div>
  </div>
</div>

<%- include('partials/content-end') %>
<%- include('partials/footer') %>
