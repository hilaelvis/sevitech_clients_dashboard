<%- include('partials/head') %>
<%- include('partials/content-start') %>

<!-- Back button -->
<div class="mb-6">
  <a href="/clients" class="text-blue-600 hover:text-blue-800 dark:text-blue-400 dark:hover:text-blue-300">
    <i class="fas fa-arrow-left mr-2"></i>Back to Clients
  </a>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <!-- Client Info Card -->
  <div class="lg:col-span-1 space-y-4">
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6">

      <!-- View Mode -->
      <div id="view-mode">
        <div class="text-center mb-4">
          <div class="w-16 h-16 bg-blue-100 dark:bg-blue-900 rounded-full flex items-center justify-center mx-auto mb-3">
            <span class="text-2xl text-blue-600 dark:text-blue-300 font-bold"><%= client.business_name ? client.business_name.charAt(0).toUpperCase() : '?' %></span>
          </div>
          <h2 class="text-xl font-bold text-gray-800 dark:text-white"><%= client.business_name || 'N/A' %></h2>
          <% if (client.category) { %>
            <span class="inline-block mt-1 text-xs bg-blue-100 dark:bg-blue-900 text-blue-700 dark:text-blue-300 px-2 py-0.5 rounded-full"><%= client.category %></span>
          <% } %>
          <button onclick="toggleEditMode()" class="mt-2 text-sm text-blue-600 hover:text-blue-800 dark:text-blue-400 dark:hover:text-blue-300">
            <i class="fas fa-edit mr-1"></i>Edit
          </button>
        </div>
      </div>

      <!-- Edit Mode -->
      <div id="edit-mode" style="display: none;">
        <form method="POST" action="/clients/<%= client.id %>/update" class="mb-4">
          <div class="space-y-3">
            <div>
              <label class="text-sm font-medium text-gray-600 dark:text-gray-400">Business Name</label>
              <input type="text" name="business_name" value="<%= client.business_name || '' %>"
                class="mt-1 w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 dark:bg-gray-700 dark:text-white text-sm" required>
            </div>
            <div>
              <label class="text-sm font-medium text-gray-600 dark:text-gray-400">Phone</label>
              <input type="text" name="phone" value="<%= client.phone || '' %>"
                class="mt-1 w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 dark:bg-gray-700 dark:text-white text-sm">
            </div>
            <div class="flex space-x-2">
              <button type="submit" class="flex-1 bg-blue-500 hover:bg-blue-600 text-white px-4 py-2 rounded-lg transition text-sm">
                <i class="fas fa-save mr-1"></i>Save
              </button>
              <button type="button" onclick="toggleEditMode()" class="flex-1 bg-gray-500 hover:bg-gray-600 text-white px-4 py-2 rounded-lg transition text-sm">
                Cancel
              </button>
            </div>
          </div>
        </form>
      </div>

      <!-- Contact details -->
      <div class="space-y-3 text-sm">
        <% if (client.phone) { %>
          <div class="flex items-start">
            <i class="fas fa-phone w-4 text-gray-400 mt-0.5 mr-3 flex-shrink-0"></i>
            <span class="text-gray-800 dark:text-white"><%= client.phone %></span>
          </div>
        <% } %>
        <% if (client.email) { %>
          <div class="flex items-start">
            <i class="fas fa-envelope w-4 text-gray-400 mt-0.5 mr-3 flex-shrink-0"></i>
            <span class="text-gray-800 dark:text-white break-all"><%= client.email %></span>
          </div>
        <% } %>
        <% if (client.address) { %>
          <div class="flex items-start">
            <i class="fas fa-map-marker-alt w-4 text-gray-400 mt-0.5 mr-3 flex-shrink-0"></i>
            <span class="text-gray-800 dark:text-white"><%= client.address %></span>
          </div>
        <% } %>
        <% if (client.website) { %>
          <div class="flex items-start">
            <i class="fas fa-globe w-4 text-gray-400 mt-0.5 mr-3 flex-shrink-0"></i>
            <a href="<%= client.website %>" target="_blank" class="text-blue-600 dark:text-blue-400 hover:underline break-all"><%= client.website %></a>
          </div>
        <% } %>
        <% if (client.rating) { %>
          <div class="flex items-center">
            <i class="fas fa-star w-4 text-gray-400 mr-3 flex-shrink-0"></i>
            <span class="text-gray-800 dark:text-white"><%= client.rating %> / 5</span>
          </div>
        <% } %>
      </div>

      <!-- Social media icons -->
      <% const hasSocials = client.facebook || client.instagram || client.linkedin || client.twitter || client.tiktok || client.youtube; %>
      <% if (hasSocials) { %>
        <div class="mt-4 pt-4 border-t border-gray-200 dark:border-gray-700">
          <p class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase mb-3">Social Media</p>
          <div class="flex items-center flex-wrap gap-3">
            <% if (client.facebook) { %>
              <a href="<%= client.facebook %>" target="_blank" title="Facebook" class="text-gray-400 hover:text-blue-600 transition text-xl"><i class="fab fa-facebook"></i></a>
            <% } %>
            <% if (client.instagram) { %>
              <a href="<%= client.instagram %>" target="_blank" title="Instagram" class="text-gray-400 hover:text-pink-500 transition text-xl"><i class="fab fa-instagram"></i></a>
            <% } %>
            <% if (client.linkedin) { %>
              <a href="<%= client.linkedin %>" target="_blank" title="LinkedIn" class="text-gray-400 hover:text-blue-700 transition text-xl"><i class="fab fa-linkedin"></i></a>
            <% } %>
            <% if (client.twitter) { %>
              <a href="<%= client.twitter %>" target="_blank" title="X / Twitter" class="text-gray-400 hover:text-black dark:hover:text-white transition text-xl"><i class="fab fa-x-twitter"></i></a>
            <% } %>
            <% if (client.tiktok) { %>
              <a href="<%= client.tiktok %>" target="_blank" title="TikTok" class="text-gray-400 hover:text-black dark:hover:text-white transition text-xl"><i class="fab fa-tiktok"></i></a>
            <% } %>
            <% if (client.youtube) { %>
              <a href="<%= client.youtube %>" target="_blank" title="YouTube" class="text-gray-400 hover:text-red-600 transition text-xl"><i class="fab fa-youtube"></i></a>
            <% } %>
          </div>
        </div>
      <% } %>

      <!-- Status & meta -->
      <div class="mt-4 pt-4 border-t border-gray-200 dark:border-gray-700 space-y-3">
        <div>
          <label class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Status</label>
          <form method="POST" action="/clients/<%= client.id %>/status" class="mt-1">
            <select name="status" onchange="this.form.submit()"
              class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 dark:bg-gray-700 dark:text-white text-sm">
              <option value="New" <%= client.status === 'New' ? 'selected' : '' %>>New</option>
              <option value="Responded" <%= client.status === 'Responded' ? 'selected' : '' %>>Responded</option>
              <option value="Interested" <%= client.status === 'Interested' ? 'selected' : '' %>>Interested</option>
              <option value="Was Sent" <%= client.status === 'Was Sent' ? 'selected' : '' %>>Was Sent</option>
              <option value="Closed" <%= client.status === 'Closed' ? 'selected' : '' %>>Closed</option>
            </select>
          </form>
        </div>

        <div>
          <label class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Conversation ID</label>
          <p class="mt-1 text-sm text-gray-800 dark:text-white font-mono"><%= client.conversation_id || 'N/A' %></p>
        </div>

        <div>
          <label class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Created</label>
          <p class="mt-1 text-sm text-gray-800 dark:text-white"><%= formatDate(client.created_time) %></p>
          <p class="text-xs text-gray-500 dark:text-gray-400"><%= formatRelativeTime(client.created_time) %></p>
        </div>

        <div>
          <label class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Messages</label>
          <p class="mt-1 text-sm text-gray-800 dark:text-white"><%= messages.length %></p>
        </div>
      </div>

      <div class="mt-4">
        <a href="/clients/<%= client.id %>/export/pdf" class="block w-full bg-blue-500 hover:bg-blue-600 text-white text-center px-4 py-2 rounded-lg transition text-sm">
          <i class="fas fa-file-pdf mr-2"></i>Export as PDF
        </a>
      </div>
    </div>
  </div>

  <!-- Conversation History -->
  <div class="lg:col-span-2">
    <div class="rounded-lg shadow overflow-hidden">
      <!-- WhatsApp Header -->
      <div class="bg-[#008069] text-white px-6 py-4 flex items-center space-x-3">
        <div class="w-10 h-10 bg-gray-200 rounded-full flex items-center justify-center">
          <span class="text-lg text-gray-700 font-semibold"><%= client.business_name ? client.business_name.charAt(0).toUpperCase() : '?' %></span>
        </div>
        <div>
          <h3 class="font-semibold"><%= client.business_name || 'Client' %></h3>
          <p class="text-xs text-gray-100"><%= client.phone || 'No phone' %></p>
        </div>
      </div>

      <!-- WhatsApp Chat Background -->
      <div class="bg-[#efeae2] p-4 max-h-[600px] overflow-y-auto" style="background-image: url('data:image/svg+xml;base64,'); background-size: 300px 300px;">
        <% if (messages.length === 0) { %>
          <div class="text-center py-12">
            <i class="fas fa-comments text-6xl text-gray-400 mb-4"></i>
            <p class="text-gray-600 dark:text-gray-400">No messages yet</p>
          </div>
        <% } else { %>
          <div class="space-y-1">
            <% messages.forEach(function(message) { %>
              <div class="flex <%= message.sender === 'Client' ? 'justify-start' : 'justify-end' %>">
                <div class="relative inline-block max-w-[85%] sm:max-w-[75%] <%= message.sender === 'Client' ? 'bg-white' : 'bg-[#d9fdd3]' %> rounded-md shadow-sm px-2 py-1" style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;">
                  <div class="absolute top-0 <%= message.sender === 'Client' ? '-left-1.5' : '-right-1.5' %> w-0 h-0" style="border-style: solid; <%= message.sender === 'Client' ? 'border-width: 0 6px 8px 0; border-color: transparent white transparent transparent;' : 'border-width: 0 0 8px 6px; border-color: transparent transparent #d9fdd3 transparent;' %>"></div>
                  <p class="text-[#111b21] text-sm leading-snug whitespace-pre-wrap break-words inline" style="word-break: break-word;"><%= message.message_text %></p>
                  <span class="text-[10px] text-gray-500 ml-2 inline-block align-bottom" style="margin-bottom: 1px;">
                    <%= new Date(message.timestamp).toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit', hour12: false }) %>
                    <% if (message.sender === 'Agent') { %>
                      <i class="fas fa-check-double text-blue-500 ml-1"></i>
                    <% } %>
                  </span>
                </div>
              </div>
            <% }) %>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</div>

<%- include('partials/content-end') %>

<script>
  function toggleEditMode() {
    const viewMode = document.getElementById('view-mode');
    const editMode = document.getElementById('edit-mode');
    if (viewMode.style.display === 'none') {
      viewMode.style.display = 'block';
      editMode.style.display = 'none';
    } else {
      viewMode.style.display = 'none';
      editMode.style.display = 'block';
    }
  }
</script>

<%- include('partials/footer') %>
